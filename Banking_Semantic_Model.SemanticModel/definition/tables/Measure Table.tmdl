	measure 'Avg Products per Customer' =
			
			VAR _DateKey = MAX(dim_date[date_key])
			VAR _Products =
			    CALCULATE(
			        SUM(fact_customer_daily_portfolio[account_count]) +
			        SUM(fact_customer_daily_portfolio[card_count]) +
			        SUM(fact_customer_daily_portfolio[loan_count]),
			        fact_customer_daily_portfolio[date_key] = _DateKey
			    )
			RETURN
			DIVIDE(_Products, [Portfolio Customers], 0)
		displayFolder: Customer Portfolio
