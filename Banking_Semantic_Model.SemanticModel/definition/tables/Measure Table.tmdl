	measure 'Customers With Card' =
			
			VAR _DateKey = MAX(dim_date[date_key])
			RETURN
			CALCULATE(
			    DISTINCTCOUNT(fact_customer_daily_portfolio[customer_key]),
			    fact_customer_daily_portfolio[date_key] = _DateKey,
