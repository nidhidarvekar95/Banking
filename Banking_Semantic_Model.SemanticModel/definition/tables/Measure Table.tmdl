	measure 'Multi Product Customers' =
			
			VAR _DateKey = MAX(dim_date[date_key])
			RETURN
			COUNTROWS(
			    FILTER(
			        fact_customer_daily_portfolio,
			        fact_customer_daily_portfolio[date_key] = _DateKey &&
			        (
			            IF(fact_customer_daily_portfolio[account_count] > 0, 1, 0) +
			            IF(fact_customer_daily_portfolio[card_count] > 0, 1, 0) +
			            IF(fact_customer_daily_portfolio[loan_count] > 0, 1, 0)
			        ) >= 2
			    )
			)
		formatString: 0
		displayFolder: Cross-sell
		lineageTag: 30d264ea-5813-4261-af93-1494573de353

