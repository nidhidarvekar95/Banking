		lineageTag: b78baa39-cb60-4bd5-9329-24c068843ec2

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Loan Growth %' =
			
			DIVIDE(
			    [Total Loan Exposure] - [Previous Period Loan Exposure],
			    [Previous Period Loan Exposure],
			    0
			)
		displayFolder: 2nd Page
		lineageTag: 9d48e730-6651-4c29-ae42-b89c813bfee0

	measure 'Previous Period Loan Exposure' =
			
			CALCULATE(
			    [Total Loan Exposure],
			    DATEADD(dim_date[Date], -1, MONTH)
			)
		displayFolder: 2nd Page
		lineageTag: 48eadab1-9514-4873-9644-20ec7bd9d246

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'NPA %' =
			
			DIVIDE(
			    CALCULATE(
			        COUNTROWS(fact_loans),
			        fact_loans[status] = "NPA"
			    ),
			    [Total Loans],
			    0
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 2nd Page
		lineageTag: f5211e0b-979a-4966-9261-8d0ddfbe440b

	measure 'Total Loan Exposure by Segment' =
			
			CALCULATE(
			    SUM(fact_loans[principal_amount]),
			    TREATAS(VALUES(dim_date[Date_Key]), fact_loans[date_key]),
			    TREATAS(VALUES(dim_customer[customer_key]), fact_loans[customer_key])
			)
		displayFolder: 2nd Page
		lineageTag: 371457b5-74a3-478c-9641-87009c413ea7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Loans by Segment' =
			
			CALCULATE(
			    COUNTROWS(fact_loans),
			    TREATAS(VALUES(dim_date[Date_Key]), fact_loans[date_key]),
			    TREATAS(VALUES(dim_customer[customer_key]), fact_loans[customer_key])
			)
		formatString: 0
		displayFolder: 2nd Page
		lineageTag: 4b4e9271-5fa3-4f05-8bb7-f9c95578912a

	measure 'Top 10 Customers %' =
			
			DIVIDE(
			    CALCULATE(
			        [Total Loan Exposure],
			        TOPN(10, VALUES(dim_customer[customer_id]), [Total Loan Exposure])
			    ),
			    [Total Loan Exposure],
			    0
			)
		displayFolder: 2nd Page
		lineageTag: c231571a-ca99-4be0-9550-e920eeb93ae6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Loan Bucket' =
			
			SWITCH(
			    TRUE(),
			    [Total Loan Exposure by Segment] < 7500000, "Small",
			    [Total Loan Exposure by Segment] < 9900000, "Medium",
			    [Total Loan Exposure by Segment] < 15000000, "Large",
			    "High Value"
			)
		displayFolder: 2nd Page
		lineageTag: effdddee-9db9-49a9-ad06-2f0e54139030

	measure 'Customers per Bucket' =
			
			CALCULATE(
			    DISTINCTCOUNT(fact_loans[customer_key]),
			    TREATAS(VALUES(dim_date[Date_Key]), fact_loans[date_key])
			)
		formatString: 0
		displayFolder: 2nd Page
		lineageTag: d05d7887-3337-429b-b630-c11bbe43ad9c

	measure 'Total Loan Exposure by Segment & Bucket' =
			
			CALCULATE(
			    SUM(fact_loans[principal_amount]),
			    TREATAS(VALUES(dim_date[Date_Key]), fact_loans[date_key]),
			    TREATAS(VALUES(dim_customer[customer_key]), fact_loans[customer_key])
			)
		displayFolder: 2nd Page
		lineageTag: b9494ced-9043-49a0-beed-e673f439c2cf

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Distinct Borrowers by Segment & Bucket' =
			
			CALCULATE(
			    DISTINCTCOUNT(fact_loans[customer_key]),
			    TREATAS(VALUES(dim_date[Date_Key]), fact_loans[date_key]),
			    TREATAS(VALUES(dim_customer[customer_key]), fact_loans[customer_key])
			)
		formatString: 0
		displayFolder: 2nd Page
		lineageTag: f515e31e-344c-4951-9951-116455863952

	measure 'Exposure %' =
			
			DIVIDE(
			    [Total Loan Exposure by Segment & Bucket],
			    [Total Loan Exposure],
			    0
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 2nd Page
		lineageTag: 58060bba-a483-4626-b055-5ba3bc1184cf

	measure 'Borrower %' = ```
			
			var a= 
			CALCULATE(
			    DISTINCTCOUNT(fact_loans[customer_key]),
			    TREATAS(VALUES(dim_date[Date_Key]), fact_loans[date_key]))
			
			    RETURN
			DIVIDE(
			    [Distinct Borrowers by Bucket],
			    a,
			    0
			) 
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 2nd Page
		lineageTag: dc62377d-d233-4e20-a6dd-252427ece2f8

	column Value
		formatString: 0
		lineageTag: 1acdaaaa-39df-4504-b2e7-a82674708734
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Value]

		annotation SummarizationSetBy = Automatic

	partition 'Measure Table' = calculated
		mode: import
		source = {1}

	annotation PBI_Id = ed4f6943f5b646709097b6e4b5ea008e

