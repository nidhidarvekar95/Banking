table 'Measure Table'
	lineageTag: bab5cd41-aa3c-4338-976d-0d523548e753

	measure 'Total Transactions' =
			
			DISTINCTCOUNT(fact_transactions[transaction_id])
		formatString: 0
		displayFolder: Transactions
		lineageTag: 9dccc067-4fb5-476a-ad25-fe3e0aaa3308

	measure 'Total Transaction Amount' =
			
			SUM(fact_transactions[amount])
		displayFolder: Transactions
		lineageTag: cdbe4fdb-2f0d-4d4b-82f8-b73564d1eed9

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Average Transaction Amount' =
			
			DIVIDE([Total Transaction Amount], [Total Transactions], 0)
		displayFolder: Transactions
		lineageTag: 1004c453-b448-47e1-b7be-3c317727b4af

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Transacting Customers' =
			
			DISTINCTCOUNT(fact_transactions[customer_key])
		formatString: 0
		displayFolder: Transactions
		lineageTag: e39669c0-09a9-487b-9b3d-1d7132cc3a40

	measure 'Transacting Accounts' =
			
			DISTINCTCOUNT(fact_transactions[account_key])
		formatString: 0
		displayFolder: Transactions
		lineageTag: e452763d-d5b2-4056-9f23-17b3db39bf6f

	measure 'Active Transaction Branches' =
			
			DISTINCTCOUNT(fact_transactions[branch_key])
		formatString: 0
		displayFolder: Transactions
		lineageTag: ea3f4d63-8937-4b34-b321-dd0a27d4f2cd

	measure 'Transactions per Customer' =
			
			DIVIDE([Total Transactions], [Transacting Customers], 0)
		displayFolder: Transactions
		lineageTag: 4849d86a-9f0c-4af5-ad34-89786c2df9ca

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Transactions per Branch' =
			
			DIVIDE([Total Transactions], [Active Transaction Branches], 0)
		displayFolder: Transactions
		lineageTag: 05968866-b786-4f9b-9735-d253eec2b8eb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Credit Transactions' =
			
			CALCULATE(
			    [Total Transactions],
			    fact_transactions[direction] = "Credit"
			)
		formatString: 0
		displayFolder: Credit/Debit
		lineageTag: 26f38ffe-4b9a-44b0-8196-30bd0b02777e

	measure 'Debit Transactions' =
			
			CALCULATE(
			    [Total Transactions],
			    fact_transactions[direction] = "Debit"
			)
		formatString: 0
		displayFolder: Credit/Debit
		lineageTag: 9286178f-e3eb-4247-8b24-975b29445d67

	measure 'Credit Amount' =
			
			CALCULATE(
			    [Total Transaction Amount],
			    fact_transactions[direction] = "Credit"
			)
		displayFolder: Credit/Debit
		lineageTag: c406507e-2ed6-4420-a564-0d029726fc54

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Debit Amount' =
			
			CALCULATE(
			    [Total Transaction Amount],
			    fact_transactions[direction] = "Debit"
			)
		displayFolder: Credit/Debit
		lineageTag: b3ce84d5-76e1-4e48-b264-077530792a12

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Net Transaction Flow' =
			
			[Credit Amount] - [Debit Amount]
		displayFolder: Credit/Debit
		lineageTag: 56a366a5-cce5-405a-a3e6-8b09ffe2484b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Credit Share %' =
			
			DIVIDE([Credit Amount], [Total Transaction Amount], 0)
		displayFolder: Credit/Debit
		lineageTag: 0ec70277-ae54-4fb7-9bf4-9360d45c4e51

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Fraud Transaction Count' =
			
			CALCULATE(
			    COUNTROWS(fact_transactions),
			    fact_transactions[is_fraud_label] = 1
			)
		formatString: 0
		displayFolder: Fraud
		lineageTag: 3a6b7190-3175-4bea-9575-3aaa0e650876

	measure 'Non Fraud Transactions' =
			
			[Total Transactions] - [Fraud Transaction Count]
		formatString: 0
		displayFolder: Fraud
		lineageTag: 087ffb33-b66c-4dfa-a8f5-3149dcc961f7

	measure 'Fraud Amount' = ```
			
			CALCULATE(
			    SUM(fact_transactions[amount]),
			    fact_transactions[is_fraud_label] = 1
			)
			
			// Fraud Amount = 
			// CALCULATE(
			//     [Total Transaction Amount],
			//     fact_transactions[is_fraud_label] = 1
			// )
			```
		displayFolder: Fraud
		lineageTag: c9869389-b05d-4ef1-8f07-35e9f7dd449e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Fraud Rate %' =
			
			DIVIDE([Fraud Transaction Count], [Total Transactions], 0)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Executive Summary
		lineageTag: 12217de5-7f19-46d3-afb3-c8b655e424bb

	measure 'Fraud Amount %' =
			
			DIVIDE([Fraud Amount], [Total Transaction Amount], 0)
		displayFolder: Fraud
		lineageTag: cebf52a3-2c07-415a-b932-a02317691c55

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Average Fraud Amount' =
			
			DIVIDE([Fraud Amount], [Fraud Transaction Count], 0)
		displayFolder: Fraud
		lineageTag: 183e86f7-1dcc-432e-8ec9-8abe9e363648

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'High Value Transactions' =
			
			CALCULATE(
			    [Total Transactions],
			    FILTER(
			        fact_transactions,
			        fact_transactions[amount] >= 100000
			    )
			)
		formatString: 0
		displayFolder: High Value Transc
		lineageTag: d7dce191-89d0-4547-b63d-46f352214247

	measure 'High Value Transaction Amount' =
			
			CALCULATE(
			    [Total Transaction Amount],
			    FILTER(
			        fact_transactions,
			        fact_transactions[amount] >= 100000
			    )
			)
		displayFolder: High Value Transc
		lineageTag: 9c3fa3c4-e303-4d89-8ce4-3f42b8aa00ab

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'High Value Fraud Transactions' =
			
			CALCULATE(
			    [Total Transactions],
			    FILTER(
			        fact_transactions,
			        fact_transactions[amount] >= 100000 &&
			        fact_transactions[is_fraud_label] = 1
			    )
			)
		formatString: 0
		displayFolder: High Value Transc
		lineageTag: 9fdaf54f-2660-46ef-bbfe-b7360d19660f

	measure 'Unique Counterparties' =
			
			DISTINCTCOUNT(fact_transactions[counterparty])
		formatString: 0
		displayFolder: Merchant
		lineageTag: 4b3ae236-d37b-4813-a3d7-5ab2f1c9cbc1

	measure 'Unique Merchant Categories' =
			
			DISTINCTCOUNT(fact_transactions[merchant_category])
		formatString: 0
		displayFolder: Merchant
		lineageTag: e84fcfd1-155d-4a18-b12d-e0b4bf549b11

	measure 'Average Amount per Counterparty' =
			
			DIVIDE([Total Transaction Amount], [Unique Counterparties], 0)
		displayFolder: Merchant
		lineageTag: 9713e746-3926-4168-a9d6-341fcd4da36b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Loans' =
			
			CALCULATE(
			    COUNTROWS(fact_loans),
			    TREATAS(VALUES(dim_date[Date_Key]), fact_loans[date_key])
			)
		formatString: 0
		displayFolder: 2nd Page
		lineageTag: 2c1facde-6eaf-4598-80d9-35f3ed68a7e7

	measure 'Loan Customers' =
			
			DISTINCTCOUNT(fact_loans[customer_key])
		formatString: 0
		displayFolder: Loan
		lineageTag: 02cd5bcd-4665-49e1-8527-bcc4a9c7975a

	measure 'Loan Branches' =
			
			DISTINCTCOUNT(fact_loans[branch_key])
		formatString: 0
		displayFolder: Loan
		lineageTag: 003a93af-08ac-42ba-890b-e2b346d05b8d

	measure 'Total Principal Disbursed' =
			
			SUM(fact_loans[principal_amount])
		displayFolder: Loan
		lineageTag: 1ff7034e-e26e-4643-b2dc-489b6802b1cd

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Average Loan Size' =
			
			DIVIDE([Total Loan Exposure], [Total Loans], 0)
		displayFolder: 2nd Page
		lineageTag: ea2dcdcb-96cd-4697-b985-5e3e18b924b1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Average Loan Tenure' =
			
			CALCULATE(
			    AVERAGE(fact_loans[tenure_months]),
			    TREATAS(VALUES(dim_date[Date_Key]), fact_loans[date_key])
			)
		displayFolder: 2nd Page
		lineageTag: 2fbadf7a-79d1-4245-b32d-0e733b7125d6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Average Interest Rate' =
			
			var a = CALCULATE(
			    AVERAGE(fact_loans[interest_rate_apr]),
			    TREATAS(VALUES(dim_date[Date_Key]), fact_loans[date_key])
			)
			RETURN
			DIVIDE(
			    a,
			    100
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 2nd Page
		lineageTag: a0352fc3-557a-4b66-ab98-72c3f7dc191f

	measure 'Weighted Avg APR' =
			
			DIVIDE(
			    SUMX(
			        fact_loans,
			        fact_loans[principal_amount] * fact_loans[interest_rate_apr]
			    ),
			    [Total Principal Disbursed],
			    0
			)
		displayFolder: Loan
		lineageTag: 09f35d7c-5d48-4a27-b6d6-371b30494f04

		annotation PBI_FormatHint = {"isGeneralNumber":true}

