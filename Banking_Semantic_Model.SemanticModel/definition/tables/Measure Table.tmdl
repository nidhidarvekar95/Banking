	measure 'Total Deposit Balance' =
			
			VAR _DateKey = --MAX(dim_date[full_date])
			MAX(dim_date[date_key])
			RETURN
			CALCULATE(
			    SUM(fact_daily_balances[end_of_day_balance]),
			    fact_daily_balances[date_key] = _DateKey
			)
		displayFolder: Deposit / balance
		lineageTag: b99894b8-5c1f-4670-90a3-787aa24a0ec8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

